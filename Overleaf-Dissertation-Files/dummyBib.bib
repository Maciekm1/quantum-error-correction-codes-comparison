	keywords = {CubeSat},
	pages = {694--699},
	file = {Submitted Version:/Users/maciek/Zotero/storage/X6JSXYF6/Jordán-Parra et al. - 2024 - Evaluation method and case study of satellite quantum key distribution for terrestrial networks.pdf:application/pdf},
}

